#!/usr/bin/env bash
set -euo pipefail

# sear - short query search with fragment scanning
#
# What it does:
# - Splits a genome into overlapping fragments
# - Runs ssearch36 against each fragment
# - Merges hits and extracts sequence with flanks
# - Optional best-hit selection and MAFFT alignment
#
# Notes:
# - Uses @U@ placeholder to keep headers short and restores names on output
# - Handles split reuse and cleans intermediate files

usage() {
  cat <<'EOF'
sear - short query search with fragment scanning (ssearch36 + bedtools)

Usage:
  sear [options] <query.fasta> <bank.fasta> [Slf=0.8] [Homology=65] [Flank=50] [KeepSplits=0]

Options:
  -b, --best [N]    Keep top N unique hits by bitscore and run MAFFT.
                    Default N=100 (ssearch36 mode).
                    Minimap2 mode auto-sets N=10 (query <5 kb) or N=5 (≥5 kb)
                    unless an explicit N is given.
  -m, --minus       Enable minus-bank depletion (multi-round per split)
  -s, --stop [N]    Stop after N total hits (default 1000)
  -k, --keep        Keep split files for reuse
  --slop L,R        Override flank sizes for bed/bnk and best-hit flanks
  --force-ssearch   Use ssearch36 even for queries ≥1000 bp (skip minimap2)

Minimap2 mode (automatic for queries ≥1000 bp):
  Searches the genome directly with minimap2 instead of fragment-scanning
  with ssearch36.  Uses a sensitivity cascade: asm5 → asm10 → asm20,
  stopping at the first preset that finds hits.
  Override with --force-ssearch to always use ssearch36.

Notes:
  --slop uses explicit left/right values. It overrides FlankSize.
EOF
}

if [[ $# -eq 0 ]]; then
  echo "No arguments supplied!"
  usage
  exit 1
fi

BEST=0
BEST_N=100
BEST_N_EXPLICIT=0
DO_MINUS=0
STOP_EARLY=0
STOP_N=1000
KEEP_FLAG=0
FORCE_SSEARCH=0
SLOP_L=""
SLOP_R=""

args=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    --best|-b)
      BEST=1
      if [[ $# -ge 2 && "$2" =~ ^[0-9]+$ ]]; then
        BEST_N="$2"
        BEST_N_EXPLICIT=1
        shift 2
      else
        shift 1
      fi
      ;;
    -b[0-9]*)
      BEST=1
      BEST_N="${1#-b}"
      BEST_N_EXPLICIT=1
      shift 1
      ;;
    --minus|-m)
      DO_MINUS=1
      shift 1
      ;;
    --stop|-s)
      STOP_EARLY=1
      if [[ $# -ge 2 && "$2" =~ ^[0-9]+$ ]]; then
        STOP_N="$2"
        shift 2
      else
        shift 1
      fi
      ;;
    -s[0-9]*)
      STOP_EARLY=1
      STOP_N="${1#-s}"
      shift 1
      ;;
    --keep|-k)
      KEEP_FLAG=1
      shift 1
      ;;
    --force-ssearch)
      FORCE_SSEARCH=1
      shift 1
      ;;
    --slop)
      if [[ $# -ge 2 && "$2" =~ ^[0-9]+,[0-9]+$ ]]; then
        SLOP_L="${2%,*}"
        SLOP_R="${2#*,}"
        shift 2
      else
        echo "Invalid --slop value (use L,R)"
        exit 1
      fi
      ;;
    --slop=*)
      slop_val="${1#--slop=}"
      if [[ "$slop_val" =~ ^[0-9]+,[0-9]+$ ]]; then
        SLOP_L="${slop_val%,*}"
        SLOP_R="${slop_val#*,}"
        shift 1
      else
        echo "Invalid --slop value (use L,R)"
        exit 1
      fi
      ;;
    --)
      shift
      args+=("$@")
      break
      ;;
    *)
      args+=("$1")
      shift
      ;;
  esac
done
set -- "${args[@]}"

if [[ $# -lt 2 || "$1" == -* || "$2" == -* ]]; then
  usage
  exit 1
fi

query_in="$1"
bank_in="$2"

if [[ ! -f "$query_in" ]]; then
  echo "File $query_in: not found"
  exit 1
fi
if [[ ! -f "$bank_in" ]]; then
  echo "File $bank_in: not found"
  exit 1
fi

need_bins=(bedtools samtools)
if [[ $BEST -eq 1 ]]; then
  need_bins+=(mafft)
fi
for b in "${need_bins[@]}"; do
  if ! command -v "$b" >/dev/null 2>&1; then
    echo "Program $b: not found in PATH"
    exit 1
  fi
done

ORIGINAL_BANK="$bank_in"
WORKING_BANK="$bank_in"
TEMP_BANK_CREATED=0

if [[ -f "$ORIGINAL_BANK".fai ]]; then
  echo "fai index found"
else
  echo "Creating fai index..."
  samtools faidx "$ORIGINAL_BANK"
fi

underscores=$(awk '/_/' "$ORIGINAL_BANK".fai 2>/dev/null || true)
tabs_in_headers=$(head -n 100 "$ORIGINAL_BANK" 2>/dev/null | grep -c $'^>[^\t]*\t' || true)
tabs_in_headers="${tabs_in_headers:-0}"

if [[ -n "$underscores" ]] || [[ "$tabs_in_headers" -gt 0 ]]; then
  TEMP_BANK="${ORIGINAL_BANK%.*}_temp_clean.${ORIGINAL_BANK##*.}"

  # Reuse existing cleaned bank if it is newer than the original
  if [[ -f "$TEMP_BANK" && -f "$TEMP_BANK".fai && "$TEMP_BANK" -nt "$ORIGINAL_BANK" ]]; then
    echo "Reusing existing cleaned bank: $TEMP_BANK"
  else
    echo "WARNING: Bank file contains underscores or tabs in sequence names"
    echo "Creating temporary copy with simple sequence names..."

    # KEY FIX: Use @U@ instead of @UNDERSCORE@ (saves 10 chars per underscore!)
    awk '
    /^>/ {
        name = $1
        sub(/^>/, "", name)
        gsub(/_/, "@U@", name)
        print ">" name
        next
    }
    { print }
    ' "$ORIGINAL_BANK" > "$TEMP_BANK"

    samtools faidx "$TEMP_BANK"
  fi

  WORKING_BANK="$TEMP_BANK"
  TEMP_BANK_CREATED=1
  echo "Using temporary cleaned bank: $WORKING_BANK"
else
  echo "No underscores or tabs detected - using original bank file"
fi

Slf=${3:-0.8}
Homology=${4:-65}
FlankSize=${5:-50}
KeepSplits=${6:-0}

MainSlopL="$FlankSize"
MainSlopR="$FlankSize"
BestSlopL=50
BestSlopR=50

if [[ -n "$SLOP_L" ]]; then
  MainSlopL="$SLOP_L"
  MainSlopR="$SLOP_R"
  BestSlopL="$SLOP_L"
  BestSlopR="$SLOP_R"
fi

# -k overrides positional KeepSplits
if [[ $KEEP_FLAG -eq 1 ]]; then
  KeepSplits=1
fi

# Clean up any stale files from previous queries BEFORE starting
echo "Cleaning up any stale files from prior runs..."
rm -f minus_* plus_to_add_* _ssearch_sorted_* [0-9]*_*.bed *_s.fai \
     "$WORKING_BANK".all "$WORKING_BANK".all_hits.txt \
     "$WORKING_BANK".stripped.genome "$WORKING_BANK".minimap_raw.txt \
     2>/dev/null || true

len=$(awk '/^>/{if (l!="") print l; l=0; next}{l+=length($0)}END{print l}' "$query_in")
flen=$(awk -v a=$Slf -v b=$len 'BEGIN{print int(a*b)}')
echo "Query length = $len bp, overlap = $flen bp"

query="$query_in"
qname="${query%.*}"
taxname=$(echo "$WORKING_BANK" | cut -c 1-3)

# --- Per-query intermediates cleanup (ALWAYS) ---
cleanup_query() {
  rm -f minus_* plus_to_add_* _ssearch_sorted_* [0-9]*_*.bed *_s.fai \
       "$WORKING_BANK".all "$WORKING_BANK".all_hits.txt \
       "$WORKING_BANK".stripped.genome "$WORKING_BANK".minimap_raw.txt \
       2>/dev/null || true
}
trap cleanup_query EXIT

# ═══════════════════════════════════════════════════════════════════════
# Detect minimap2 mode (query ≥ 1000 bp)
# ═══════════════════════════════════════════════════════════════════════
MINIMAP_MODE=0
if [[ $len -ge 1000 && $FORCE_SSEARCH -eq 0 ]]; then
  if command -v minimap2 >/dev/null 2>&1; then
    MINIMAP_MODE=1
  else
    echo "WARNING: minimap2 not found — falling back to ssearch36 mode"
  fi
fi

if [[ $MINIMAP_MODE -eq 1 ]]; then
  echo "Query >= 1000 bp — minimap2 mode (cascade: asm5 → asm10 → asm20)"

  # Auto-adjust -b N when not explicitly set
  if [[ $BEST -eq 1 && $BEST_N_EXPLICIT -eq 0 ]]; then
    if [[ $len -lt 5000 ]]; then
      BEST_N=10
    else
      BEST_N=5
    fi
    echo "Auto-setting -b to $BEST_N (query ${len} bp)"
  fi

  # .stripped.genome for bedtools (no _sliding suffixes in minimap2 mode)
  awk 'BEGIN{OFS="\t"} {print $1, $2}' "$WORKING_BANK".fai \
    | sort -V > "$WORKING_BANK".stripped.genome

  # Cascade: asm5 → asm10 → asm20 (stop at first preset with hits that are LONG)
  MM2_FOUND=0
  for preset in asm10 asm20; do
    echo "  minimap2 -x $preset ..."
    minimap2 -x "$preset" \
      -t "${THREADS:-$(nproc 2>/dev/null || echo 1)}" \
      --secondary=yes -p 0.3 -N 10000 \
      "$WORKING_BANK" "$query" 2>/dev/null \
    | awk 'BEGIN{OFS="\t"}
        {
          if (NF < 12) next
          strand = $5; if (strand != "+" && strand != "-") next
          tname  = $6; tstart = $8+0; tend = $9+0
          qstart = $3+0; qend = $4+0
          matches = $10+0
          if (tend <= tstart || qend <= qstart) next
          qlen_aln = qend - qstart
          tlen_aln = tend - tstart
          # Identity: matches / min(query_len, target_len) to penalize gaps
          min_len = (qlen_aln < tlen_aln) ? qlen_aln : tlen_aln
          if (min_len <= 0) next
          pct_id = matches / min_len * 100
          alen   = tlen_aln
          as = 0
          for (i = 13; i <= NF; i++) {
            if ($i ~ /^AS:i:/) { split($i, a, ":"); as = a[3]+0 }
          }
          print tname, tstart, tend, pct_id, alen, strand, as
        }' > "$WORKING_BANK".minimap_raw.txt

    mm2_n=$(wc -l < "$WORKING_BANK".minimap_raw.txt)
    echo "  $preset: $mm2_n raw alignments"
    if [[ $mm2_n -gt 0 ]]; then
      MM2_FOUND=1
      break
    fi
  done

  if [[ $MM2_FOUND -eq 0 ]]; then
    echo "No hits from minimap2 — empty result"
    : > "$taxname-$qname.bed"
  else
    # Merge ALL raw alignments first to chain fragments, THEN filter on merged results
    bedtools sort -i "$WORKING_BANK".minimap_raw.txt 2>/dev/null \
    | bedtools merge -s -i - -c 4,5,6,7 -o max,max,distinct,max 2>/dev/null \
    | awk -v hom="$Homology" -v minlen="$flen" \
      'BEGIN{OFS="\t"} $4 >= hom && ($3 - $2) >= minlen' \
    > "$taxname-$qname.bed"

    # Apply -s / --stop limit (keep top N by bitscore)
    if [[ $STOP_EARLY -eq 1 ]]; then
      sort -k7,7nr "$taxname-$qname.bed" \
        | head -n "$STOP_N" \
        | bedtools sort -i - 2>/dev/null \
        > "$taxname-$qname.bed.tmp"
      mv "$taxname-$qname.bed.tmp" "$taxname-$qname.bed"
    fi

    echo "$(wc -l < "$taxname-$qname.bed") merged hits"
  fi

  rm -f "$WORKING_BANK".minimap_raw.txt

else
# ═══════════════════════════════════════════════════════════════════════
# ssearch36 mode (original fragment-scanning approach)
# ═══════════════════════════════════════════════════════════════════════

# Check ssearch36-mode dependencies
for b in ssearch36 seqkit; do
  if ! command -v "$b" >/dev/null 2>&1; then
    echo "Program $b: not found in PATH"
    exit 1
  fi
done

# --- Split creation/reuse (directory-local) ---
# Create splits only once per working directory (reused across queries in Step1)
if compgen -G "*.2k.part_*.bnk" >/dev/null 2>&1; then
  echo "skipping 2k split"
else
  seqkit sliding -g -s 2000 -W 2500 "$WORKING_BANK" > "$WORKING_BANK"."2k.bnk"
  seqkit split2 -p 20 -O . "$WORKING_BANK"."2k.bnk"
fi

: > "$WORKING_BANK".all_hits.txt

HIT_COUNT=0
STOP_NOW=0

for bank in *.2k.part_*.bnk; do
  [[ "$bank" == minus_* ]] && continue
  [[ "$bank" == *.fai ]] && continue
  [[ "$bank" == *_s.fai ]] && continue

  echo "searching $query in $bank"
  taxname=$(echo "$bank" | cut -c 1-3)

  round=1
  Pl=1

  while [[ $Pl != "0" ]]; do
    echo "round $round"
    echo "$query $bank"

    ssearch36 -g -3 -T "${THREADS:-$(nproc 2>/dev/null || echo 1)}" -Q -n -z 11 -E 2 -w 95 -W 70 -m 8C "$query" "$bank" 3 \
    | awk '/^[^#]/ {
        printf($2"\t"$9-1"\t"$10"\t"$10-$9+1"\t");
        if ($8-$7>0) print $8-$7+1"\t+\t"$3"\t"$12;
        else print -($8-$7+1)"\t-\t"$3"\t"$12
      }' \
    | sort -V > _ssearch_sorted_"$round"_"$bank".tmp

    if [[ -s _ssearch_sorted_"$round"_"$bank".tmp ]]; then
      bedtools merge -s -c 4,5,6,7,8 -o max,max,distinct,max,max \
        < _ssearch_sorted_"$round"_"$bank".tmp 2>/dev/null \
      | awk '{if ($7>='"$Homology"' && $4>='"$flen"') print}' \
      | sort -V > plus_to_add_"$round"_"$bank".bed
    else
      : > plus_to_add_"$round"_"$bank".bed
    fi
    rm -f _ssearch_sorted_"$round"_"$bank".tmp

    Pl=$(wc -l < plus_to_add_"$round"_"$bank".bed)
    echo "$Pl hits"

    cat plus_to_add_"$round"_"$bank".bed >> "$WORKING_BANK".all_hits.txt

    HIT_COUNT=$((HIT_COUNT + Pl))
    if [[ $STOP_EARLY -eq 1 && $HIT_COUNT -ge $STOP_N ]]; then
      echo "[STOP] Reached $HIT_COUNT hits (limit $STOP_N). Stopping further searches."
      STOP_NOW=1
      break
    fi

    samtools faidx "$bank" >/dev/null 2>&1 || true
    sort -V "$bank".fai > "${bank}_s.fai"

    if [[ "$Pl" == "0" ]]; then
      round=$((round+1))
      break
    fi

    if [[ $DO_MINUS -eq 0 ]]; then
      break
    fi

    echo "creating minus bank"
    cat plus_to_add_*_"$bank".bed | sort -V > "$round"_"$bank".bed

    bedtools complement -i "$round"_"$bank".bed -g "${bank}_s.fai" 2>/dev/null \
      | bedtools sort -i 2>/dev/null \
      | bedtools getfasta -s -fi "$bank" -bed - 2>/dev/null \
      | awk '/^>/ && a!=1 {gsub(/[":"]/, "_")}{gsub(/["()"]/,"");a=1};a=0;1' > minus_"$round"_"$bank"

    bank=$(echo "minus_${round}_${bank}")
    round=$((round+1))
    echo "$bank $round"
  done

  if [[ $STOP_NOW -eq 1 ]]; then
    break
  fi
done

cat "$WORKING_BANK".all_hits.txt |
  awk '{sub(/_sliding:/," ")}{sub(/_sliding_/," ")}{print $2}' |
  awk '{gsub(/_/," ")}{print}' |
  awk '{gsub(/-/," -")}1' |
  awk '{sum=0;for(i=1;i<=NF;i++)if($i>0)sum+=$i}{print sum}' > "$WORKING_BANK".all

# Create genome file - handle both complete and truncated _sliding suffixes
awk 'BEGIN{OFS="\t"}
     {
       chrom=$1;
       sub(/_sliding:.*$/, "", chrom);
       sub(/_sliding_.*$/, "", chrom);
       sub(/_slidin.*$/, "", chrom);
       sub(/_slidi.*$/, "", chrom);
       sub(/_slid.*$/, "", chrom);
       sub(/_sli.*$/, "", chrom);
       sub(/_sl.*$/, "", chrom);
       if (!seen[chrom]) {
         seen[chrom]=1;
         len[chrom]=$2;
       } else if ($2 > len[chrom]) {
         len[chrom]=$2;
       }
     }
     END { for (c in len) print c, len[c] }' "$WORKING_BANK".fai | sort -V > "$WORKING_BANK".stripped.genome

paste "$WORKING_BANK".all_hits.txt "$WORKING_BANK".all \
| awk 'BEGIN{OFS="\t"} {print $0, $2+$NF, $3+$NF}' \
| awk 'BEGIN{OFS="\t"}
       {
         chrom=$1
         sub(/_sliding:.*/, "", chrom)
         sub(/_sliding_.*/, "", chrom)
         sub(/_slidin.*/, "", chrom)
         sub(/_slidi.*/, "", chrom)
         sub(/_slid.*/, "", chrom)
         sub(/_sli.*/, "", chrom)
         sub(/_sl.*/, "", chrom)
         print chrom, $(NF-1), $NF, $7, $5, $6, $8
       }' \
| bedtools sort -i - 2>/dev/null \
| bedtools slop -l 1 -r -1 -i - -g "$WORKING_BANK".stripped.genome 2>/dev/null \
| bedtools merge -s -i - -c 4,5,6,7 -o max,max,distinct,max 2>/dev/null \
> "$taxname-$qname.bed"

fi  # end minimap2/ssearch36 mode selection

if [[ $BEST -eq 1 ]]; then
  echo "Creating best hits (top $BEST_N UNIQUE hits by bitscore) + flanks L=$BestSlopL R=$BestSlopR + MAFFT..."

  if [[ $MINIMAP_MODE -eq 1 ]]; then
    # minimap2: coordinates already genome-scale — just rank by bitscore
    sort -k7,7nr "$taxname-$qname.bed" | head -n "$BEST_N" \
      > "$taxname-$qname.best${BEST_N}.bed7"
  else
    set +o pipefail
    paste "$WORKING_BANK".all_hits.txt "$WORKING_BANK".all \
    | awk 'BEGIN{OFS="\t"}
           {
             off=$NF
             chrom=$1
             sub(/_sliding:.*/, "", chrom)
             sub(/_sliding_.*/, "", chrom)
             sub(/_slidin.*/, "", chrom)
             sub(/_slidi.*/, "", chrom)
             sub(/_slid.*/, "", chrom)
             sub(/_sli.*/, "", chrom)
             sub(/_sl.*/, "", chrom)
             print chrom, $2+off, $3+off, $7, $5, $6, $8
           }' \
    | bedtools sort -i - 2>/dev/null \
    | bedtools merge -s -i - -c 4,5,6,7 -o max,max,distinct,max 2>/dev/null \
    | sort -k7,7nr \
    | head -n "$BEST_N" \
    > "$taxname-$qname.best${BEST_N}.bed7"
    set -o pipefail
  fi

  awk 'BEGIN{OFS="\t"} {print $1,$2,$3,"tmp",$7,$6}' \
    "$taxname-$qname.best${BEST_N}.bed7" \
  > "$taxname-$qname.best${BEST_N}.bed"

  bedtools slop -s -g "$WORKING_BANK".stripped.genome -l "$BestSlopL" -r "$BestSlopR" -i "$taxname-$qname.best${BEST_N}.bed" \
  2>/dev/null > "$taxname-$qname.best${BEST_N}.flank50.tmp.bed"

  awk 'BEGIN{OFS="\t"} {name=$1":"$2"-"$3; print $1,$2,$3,name,$5,$6}' \
    "$taxname-$qname.best${BEST_N}.flank50.tmp.bed" \
  > "$taxname-$qname.best${BEST_N}.flank50.bed"

  sort -k1,1 -k2,2n -k3,3n -k6,6 "$taxname-$qname.best${BEST_N}.flank50.bed" \
  | awk 'BEGIN{OFS="\t"}{key=$1"\t"$2"\t"$3"\t"$6; if(!seen[key]++){print}}' \
  > "$taxname-$qname.best${BEST_N}.flank50.uniq.bed"

  bedtools getfasta -s -nameOnly -fi "$WORKING_BANK" -bed "$taxname-$qname.best${BEST_N}.flank50.uniq.bed" \
  2>/dev/null > "$taxname-$qname.best${BEST_N}.fa"

  mafft_in="$taxname-$qname.best${BEST_N}.mafft.in.fa"
  mafft_out="$taxname-$qname.best${BEST_N}.mafft.fa"
  mafft_err="$taxname-$qname.best${BEST_N}.mafft.err"

  {
    cat "$query"
    echo
    cat "$taxname-$qname.best${BEST_N}.fa"
  } > "$mafft_in"

      mafft --thread "${THREADS:-$(nproc 2>/dev/null || echo 1)}" --threadtb "${THREADS:-$(nproc 2>/dev/null || echo 1)}" --threadit "${THREADS:-$(nproc 2>/dev/null || echo 1)}" \
        --localpair --maxiterate 1000 --ep 0.123 --nuc --reorder --quiet \
        "$mafft_in" > "$mafft_out" 2> "$mafft_err"

  if [[ ! -s "$mafft_out" ]]; then
    echo "MAFFT produced empty output. See $mafft_err" >&2
    exit 1
  fi

  rm -f "$mafft_in"

  rm -f "$taxname-$qname.best${BEST_N}.bed7" "$taxname-$qname.best${BEST_N}.flank50.tmp.bed"
  echo "MAFFT alignment: $taxname-$qname.best${BEST_N}.mafft.fa"
fi

echo "Extracting sequences"

# Create final extracted bank
bname="$WORKING_BANK"
bedtools slop -s -i "$taxname-$qname.bed" -g "$WORKING_BANK".stripped.genome -l "$MainSlopL" -r "$MainSlopR" 2>/dev/null > "$taxname.bed"
bedtools getfasta -s -fi "$bname" -bed "$taxname.bed" 2>/dev/null > "$taxname-$qname.bnk"
rm -f "$taxname.bed"

if [[ $TEMP_BANK_CREATED -eq 1 ]]; then
  echo "Restoring original sequence names in output files..."

  awk '{gsub(/@U@/,"_")}1' "$taxname-$qname.bed" > "${taxname}-${qname}.bed.tmp"
  mv "${taxname}-${qname}.bed.tmp" "$taxname-$qname.bed"

  awk '{gsub(/@U@/,"_")}1' "$taxname-$qname.bnk" > "${taxname}-${qname}.bnk.tmp"
  mv "${taxname}-${qname}.bnk.tmp" "$taxname-$qname.bnk"

  if [[ $BEST -eq 1 ]]; then
    awk '{gsub(/@U@/,"_")}1' "$taxname-$qname.best${BEST_N}.bed" > "${taxname}-${qname}.best${BEST_N}.bed.tmp"
    mv "${taxname}-${qname}.best${BEST_N}.bed.tmp" "$taxname-$qname.best${BEST_N}.bed"

    awk '{gsub(/@U@/,"_")}1' "$taxname-$qname.best${BEST_N}.flank50.bed" > "${taxname}-${qname}.best${BEST_N}.flank50.bed.tmp"
    mv "${taxname}-${qname}.best${BEST_N}.flank50.bed.tmp" "$taxname-$qname.best${BEST_N}.flank50.bed"

    awk '{gsub(/@U@/,"_")}1' "$taxname-$qname.best${BEST_N}.flank50.uniq.bed" > "${taxname}-${qname}.best${BEST_N}.flank50.uniq.bed.tmp"
    mv "${taxname}-${qname}.best${BEST_N}.flank50.uniq.bed.tmp" "$taxname-$qname.best${BEST_N}.flank50.uniq.bed"

    awk '{gsub(/@U@/,"_")}1' "$taxname-$qname.best${BEST_N}.fa" > "${taxname}-${qname}.best${BEST_N}.fa.tmp"
    mv "${taxname}-${qname}.best${BEST_N}.fa.tmp" "$taxname-$qname.best${BEST_N}.fa"

    awk '{gsub(/@U@/,"_")}1' "$taxname-$qname.best${BEST_N}.mafft.fa" > "${taxname}-${qname}.best${BEST_N}.mafft.fa.tmp"
    mv "${taxname}-${qname}.best${BEST_N}.mafft.fa.tmp" "$taxname-$qname.best${BEST_N}.mafft.fa"
  fi

  echo "Cleanup complete"
fi

if [[ $BEST -eq 1 ]]; then
  rm -f "$taxname-$qname.best${BEST_N}.bed" \
        "$taxname-$qname.best${BEST_N}.bed7" \
        "$taxname-$qname.best${BEST_N}.fa" \
        "$taxname-$qname.best${BEST_N}.flank50.bed" \
        "$taxname-$qname.best${BEST_N}.flank50.tmp.bed" \
        "$taxname-$qname.best${BEST_N}.flank50.uniq.bed" \
        "$taxname-$qname.best${BEST_N}.mafft.err" \
        2>/dev/null || true
fi

# Remove aux fai files created for parts (these are not reused)
rm -f *2k.bnk.fai *_s.fai 2>/dev/null || true

# Split files: keep or remove depending on KeepSplits
if [[ $MINIMAP_MODE -eq 0 ]]; then
  if [[ $KeepSplits -eq 0 ]]; then
    rm -f *.2k.bnk *.2k.bnk.fai *.2k.part_* *.2k.part_*.bnk.fai *_s.fai 2>/dev/null || true
    echo "Temporary split files removed"
  else
    echo "Temporary split files kept for re-use"
  fi
fi

# Temporary cleaned bank: keep when -k is set (reused across queries)
if [[ $TEMP_BANK_CREATED -eq 1 ]]; then
  if [[ $KeepSplits -eq 0 ]]; then
    echo "Removing temporary cleaned bank file..."
    rm -f "$TEMP_BANK" "$TEMP_BANK".fai 2>/dev/null || true
  else
    echo "Temporary cleaned bank kept for re-use"
  fi
fi

# Always cleanup minus + per-query intermediates
cleanup_query
trap - EXIT

Result=$(wc -l "$taxname-$qname.bed" 2>/dev/null || true)
echo "Result lines: $Result"
